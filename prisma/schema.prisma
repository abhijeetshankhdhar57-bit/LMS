generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      Role     @default(LEARNER)
  scores    Score[]
  answers   Answer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  LEARNER
}

model Video {
  id          String     @id @default(uuid())
  title       String
  description String?
  url         String
  questions   Question[]
  scores      Score[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Question {
  id        String       @id @default(uuid())
  videoId   String
  video     Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  text      String
  type      QuestionType
  options   String     // For MCQ, store array of options as JSON string
  answers   Answer[]
  createdAt DateTime     @default(now())
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
}

model Answer {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responseText String
  isCorrect    Boolean? // For MCQ or manual grading
  createdAt    DateTime @default(now())

  @@unique([userId, questionId]) // One answer per question per user
}

model Score {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  score      Int
  total      Int
  completedAt DateTime @default(now())

  @@unique([userId, videoId]) // One score per video per user
}
